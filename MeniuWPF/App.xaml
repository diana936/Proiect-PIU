<Application x:Class="MeniuWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>

        
        <Color x:Key="PrimaryColor">#0D0208</Color>      
        <Color x:Key="GreenColor">#00FF41</Color>        
        <Color x:Key="DarkGreenColor">#007A1F</Color>    
        <Color x:Key="RedColor">#FF2222</Color>         
        <Color x:Key="YellowColor">#FFE600</Color>       
        <Color x:Key="CyanColor">#00FFFF</Color>         
        <Color x:Key="MagentaColor">#FF00FF</Color>      
        <Color x:Key="WhiteColor">#E8E8E8</Color>
        <Color x:Key="DarkBorderColor">#003B0F</Color>  
        <Color x:Key="PanelColor">#0A1A0A</Color>        

        <SolidColorBrush x:Key="PrimaryBrush"    Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="GreenBrush"      Color="{StaticResource GreenColor}"/>
        <SolidColorBrush x:Key="DarkGreenBrush"  Color="{StaticResource DarkGreenColor}"/>
        <SolidColorBrush x:Key="RedBrush"        Color="{StaticResource RedColor}"/>
        <SolidColorBrush x:Key="YellowBrush"     Color="{StaticResource YellowColor}"/>
        <SolidColorBrush x:Key="CyanBrush"       Color="{StaticResource CyanColor}"/>
        <SolidColorBrush x:Key="MagentaBrush"    Color="{StaticResource MagentaColor}"/>
        <SolidColorBrush x:Key="WhiteBrush"      Color="{StaticResource WhiteColor}"/>
        <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource DarkBorderColor}"/>
        <SolidColorBrush x:Key="PanelBrush"      Color="{StaticResource PanelColor}"/>

        
        <Style x:Key="PixelButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource GreenBrush}"/>
            <Setter Property="FontFamily"      Value="Lucida Console, Courier New"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="16,10"/>
            <Setter Property="Margin"          Value="0,6"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush"     Value="{StaticResource GreenBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            
                            <Border Background="{StaticResource DarkGreenBrush}"
                                    Margin="4,4,0,0" CornerRadius="0"/>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="0,0,4,4" CornerRadius="0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="{StaticResource DarkGreenBrush}"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="Margin" Value="4,4,0,0"/>
                                <Setter TargetName="MainBorder" Property="Background" Value="{StaticResource GreenBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="GameButton"  TargetType="Button" BasedOn="{StaticResource PixelButton}"/>

        
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource PixelButton}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding"  Value="10,6"/>
            <Setter Property="Margin"   Value="4"/>
        </Style>

        
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PixelButton}">
            <Setter Property="Foreground"   Value="{StaticResource RedBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource RedBrush}"/>
        </Style>

        
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="Foreground"          Value="{StaticResource GreenBrush}"/>
            <Setter Property="FontFamily"          Value="Lucida Console, Courier New"/>
            <Setter Property="FontSize"            Value="24"/>
            <Setter Property="FontWeight"          Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin"              Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00FF41" ShadowDepth="0" BlurRadius="12" Opacity="0.7"/>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
            <Setter Property="FontFamily" Value="Lucida Console, Courier New"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource GreenBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource GreenBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontFamily"      Value="Lucida Console, Courier New"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="{StaticResource GreenBrush}"/>
        </Style>

        
        <Style x:Key="PixelPanel" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource GreenBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding"         Value="12"/>
        </Style>

    </Application.Resources>
</Application>
