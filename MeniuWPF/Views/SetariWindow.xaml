<Window x:Class="MeniuWPF.Views.SetariWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Setari" Height="400" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource PrimaryBrush}">
    <StackPanel Margin="40,20">

        <TextBlock Text="⚙️ SETARI" Style="{StaticResource TitleText}" FontSize="26"/>

        <!-- Resolution -->
        <TextBlock Text="Rezolutie consola:" Style="{StaticResource LabelText}"/>
        <ComboBox x:Name="CmbRezolutie"
                  Background="{StaticResource AccentBrush2}"
                  Foreground="{StaticResource TextBrush}"
                  FontSize="14" Padding="8,6"
                  Margin="0,0,0,16">
            <ComboBoxItem Content="Mica  (80 x 24)"/>
            <ComboBoxItem Content="Medie (120 x 30)" IsSelected="True"/>
            <ComboBoxItem Content="Mare  (160 x 40)"/>
        </ComboBox>

        <!-- Speed -->
        <TextBlock Text="Viteza joc:" Style="{StaticResource LabelText}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Slider x:Name="SliderViteza"
                    Minimum="1" Maximum="10" Value="3"
                    Width="250" VerticalAlignment="Center"
                    Foreground="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="TxtViteza"
                       Text="3"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="14" Margin="12,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Sound -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
            <TextBlock Text="Sunet:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <CheckBox x:Name="ChkSunet"
                      Foreground="{StaticResource TextBrush}"
                      FontSize="14"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Salveaza"        Style="{StaticResource SmallButton}" Click="BtnSalveaza_Click"/>
            <Button Content="Reset Implicite" Style="{StaticResource SmallButton}"
                    Background="{StaticResource AccentBrush}" Click="BtnReset_Click"/>
            <Button Content="Inchide"         Style="{StaticResource SmallButton}"
                    Background="#333" Click="BtnClose_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
