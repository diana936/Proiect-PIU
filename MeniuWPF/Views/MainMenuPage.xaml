<Page x:Class="MeniuWPF.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource PrimaryBrush}">
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="80,0">

            <!-- ASCII art title -->
            <TextBlock FontFamily="Lucida Console, Courier New"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource GreenBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,4"
                       xml:space="preserve">
     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚ēó     
    ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ     
    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ     
    ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ     
    ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
    ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ</TextBlock>

            <TextBlock Text="A R E N A"
                       FontFamily="Lucida Console, Courier New"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource CyanBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00FFFF" ShadowDepth="0" BlurRadius="14" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Text="[ INSERT COIN TO PLAY ]"
                       FontFamily="Lucida Console, Courier New"
                       FontSize="11"
                       Foreground="{StaticResource YellowBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,28"/>

            <Button Content="[1]  SNAKE"       Style="{StaticResource GameButton}" Click="BtnSnake_Click"/>
            <Button Content="[2]  X SI ZERO"   Style="{StaticResource GameButton}" Click="BtnXSiZero_Click"/>
            <Button Content="[3]  CONNECT 4"   Style="{StaticResource GameButton}" Click="BtnConnect4_Click"/>

            <Rectangle Height="2" Fill="{StaticResource DarkGreenBrush}" Margin="0,10"/>

            <Button Content="[H]  LEADERBOARD" Style="{StaticResource GameButton}" Click="BtnLeaderboard_Click"/>
            <Button Content="[P]  JUCATORI"    Style="{StaticResource GameButton}" Click="BtnJucatori_Click"/>
            <Button Content="[S]  SETARI"      Style="{StaticResource GameButton}" Click="BtnSetari_Click"/>
            <Button Content="[Q]  EXIT"
                    Style="{StaticResource GameButton}"
                    Foreground="{StaticResource RedBrush}"
                    BorderBrush="{StaticResource RedBrush}"
                    Click="BtnExit_Click"
                    Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Page>
