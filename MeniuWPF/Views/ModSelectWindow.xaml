<Window x:Class="MeniuWPF.Views.ModSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alege Modul" Height="280" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource PrimaryBrush}">
    <StackPanel VerticalAlignment="Center" Margin="50,0">
        <TextBlock Text="Alege Modul de Joc"
                   Style="{StaticResource TitleText}"
                   FontSize="22"/>

        <Button Content="👥  2 Jucatori"
                Style="{StaticResource GameButton}"
                Click="BtnDoi_Click"/>

        <Button Content="🤖  vs Calculator"
                Style="{StaticResource GameButton}"
                Click="BtnCalculator_Click"/>

        <Button Content="Inapoi"
                Style="{StaticResource GameButton}"
                Background="#333"
                Click="BtnBack_Click"/>
    </StackPanel>
</Window>
