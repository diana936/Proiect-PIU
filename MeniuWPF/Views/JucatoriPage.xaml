<Page x:Class="MeniuWPF.Views.JucatoriPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:MeniuWPF.Views"
      Background="{StaticResource PrimaryBrush}">
    <Grid>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="&gt;&gt; JUCATORI &lt;&lt;" Style="{StaticResource TitleText}"/>

            <TextBlock x:Name="TxtStatus" Grid.Row="1"
                       FontFamily="Lucida Console, Courier New" FontSize="11"
                       Foreground="{StaticResource CyanBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <Border Grid.Row="2" BorderBrush="{StaticResource GreenBrush}" BorderThickness="2" Margin="0,0,0,12">
                <ListBox x:Name="lstJucatori"
                         Background="{StaticResource PanelBrush}"
                         Foreground="{StaticResource GreenBrush}"
                         BorderThickness="0"
                         FontFamily="Lucida Console, Courier New"
                         FontSize="11"/>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="[+ ADD]" Style="{StaticResource SmallButton}" Click="btnAdauga_Click"/>
                <Button Content="[EDIT]"  Style="{StaticResource SmallButton}"
                        Foreground="{StaticResource YellowBrush}"
                        BorderBrush="{StaticResource YellowBrush}"
                        Click="btnEditeaza_Click"/>
                <Button Content="[BACK]"  Style="{StaticResource SmallButton}"
                        Foreground="{StaticResource RedBrush}"
                        BorderBrush="{StaticResource RedBrush}"
                        Click="btnInapoi_Click"/>
            </StackPanel>
        </Grid>

        <local:PixelOverlay x:Name="Overlay"/>
    </Grid>
</Page>
