<Window x:Class="MeniuWPF.Views.Connect4Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect 4" Height="620" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource PrimaryBrush}">
    <StackPanel Margin="20">

        <TextBlock Text="🔴  CONNECT 4" Style="{StaticResource TitleText}" FontSize="26"/>

        <TextBlock x:Name="TxtStatus"
                   Text="Turul: Jucator 1 (R)"
                   Foreground="{StaticResource GreenBrush}"
                   FontSize="15" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12"/>

        <!-- Column buttons (drop token) -->
        <StackPanel x:Name="ColButtons" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4"/>

        <!-- 6x7 Board -->
        <Grid x:Name="BoardGrid" HorizontalAlignment="Center"/>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="Restart" Style="{StaticResource SmallButton}" Click="BtnRestart_Click"/>
            <Button Content="Inapoi"  Style="{StaticResource SmallButton}" Background="#333" Click="BtnBack_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
