<Page x:Class="MeniuWPF.Views.AdaugaJucatorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      Background="{StaticResource PrimaryBrush}">
    <Page.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="FontFamily" Value="Lucida Console, Courier New"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="0,8,0,2"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
            <Setter Property="FontFamily" Value="Lucida Console, Courier New"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,3"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
            <Setter Property="FontFamily" Value="Lucida Console, Courier New"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,14,0"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,20">

            <TextBlock x:Name="txtTitlu" Text="&gt;&gt; ADAUGA JUCATOR &lt;&lt;"
                       Style="{StaticResource TitleText}" FontSize="18"/>

            <Label x:Name="lblNume" Content="NUME JUCATOR:"/>
            <TextBox x:Name="txtNume" Style="{StaticResource ModernTextBox}"/>
            <TextBlock x:Name="errNume" Foreground="{StaticResource RedBrush}"
                       FontFamily="Lucida Console, Courier New" FontSize="10"
                       Visibility="Collapsed" Margin="0,2,0,0"/>

            <Label x:Name="lblDificultate" Content="NIVEL DIFICULTATE:"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <RadioButton x:Name="rbUsor"    Content="USOR"    GroupName="Dif" IsChecked="True"/>
                <RadioButton x:Name="rbMediu"   Content="MEDIU"   GroupName="Dif"/>
                <RadioButton x:Name="rbDificil" Content="DIFICIL" GroupName="Dif"
                             Foreground="{StaticResource YellowBrush}"/>
                <RadioButton x:Name="rbExpert"  Content="EXPERT"  GroupName="Dif"
                             Foreground="{StaticResource RedBrush}"/>
            </StackPanel>

            <Label Content="OPTIUNI JUCATOR:"/>
            <CheckBox x:Name="chkSunet"     Content="SUNET ACTIVAT"/>
            <CheckBox x:Name="chkMuzica"    Content="MUZICA ACTIVATA"/>
            <CheckBox x:Name="chkAnimatii"  Content="ANIMATII ACTIVE"/>
            <CheckBox x:Name="chkIntuneric" Content="MOD INTUNECAT"/>

            <Label Content="JOC PREFERAT:"/>
            <ComboBox x:Name="cmbJocPreferat"
                      Background="{StaticResource PanelBrush}"
                      Foreground="{StaticResource GreenBrush}"
                      BorderBrush="{StaticResource GreenBrush}"
                      FontFamily="Lucida Console, Courier New"
                      FontSize="11" Padding="6,4" Margin="0,0,0,6">
                <ComboBoxItem Content="SNAKE"     IsSelected="True"/>
                <ComboBoxItem Content="X SI ZERO"/>
                <ComboBoxItem Content="CONNECT 4"/>
            </ComboBox>

            <Label Content="DATA INREGISTRARII:"/>
            <DatePicker x:Name="dpData"
                        Background="{StaticResource PanelBrush}"
                        Foreground="{StaticResource GreenBrush}"
                        BorderBrush="{StaticResource GreenBrush}"
                        FontFamily="Lucida Console, Courier New"
                        FontSize="11"
                        SelectedDate="{x:Static sys:DateTime.Today}"
                        Margin="0,0,0,6"/>

            <Label Content="SCOR INITIAL:"/>
            <Border BorderBrush="{StaticResource GreenBrush}" BorderThickness="2" Margin="0,0,0,4">
                <ListBox x:Name="lstScor" Height="80"
                         Background="{StaticResource PanelBrush}"
                         Foreground="{StaticResource GreenBrush}"
                         BorderThickness="0"
                         FontFamily="Lucida Console, Courier New" FontSize="11">
                    <ListBoxItem Content="0"    IsSelected="True"/>
                    <ListBoxItem Content="100"/>
                    <ListBoxItem Content="250"/>
                    <ListBoxItem Content="500"/>
                    <ListBoxItem Content="1000"/>
                </ListBox>
            </Border>
            <TextBlock x:Name="errScor" Foreground="{StaticResource RedBrush}"
                       FontFamily="Lucida Console, Courier New" FontSize="10"
                       Visibility="Collapsed" Margin="0,2,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="btnSalveaza" Content="[SAVE]"
                        Style="{StaticResource SmallButton}" Click="btnSalveaza_Click"/>
                <Button x:Name="btnAnuleaza" Content="[CANCEL]"
                        Style="{StaticResource SmallButton}"
                        Foreground="{StaticResource RedBrush}"
                        BorderBrush="{StaticResource RedBrush}"
                        Click="btnAnuleaza_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
