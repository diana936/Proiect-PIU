<Page x:Class="MeniuWPF.Views.XSiZeroPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:MeniuWPF.Views"
      Background="{StaticResource PrimaryBrush}">
    <Page.Resources>
        <Style x:Key="CellBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource GreenBrush}"/>
            <Setter Property="FontFamily"      Value="Lucida Console, Courier New"/>
            <Setter Property="FontSize"        Value="42"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush"     Value="{StaticResource DarkGreenBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#001A00"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource GreenBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="{StaticResource DarkGreenBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="30">
            <TextBlock Text="&gt;&gt; X SI ZERO &lt;&lt;" Style="{StaticResource TitleText}"/>
            <TextBlock x:Name="TxtDif"
                       FontFamily="Lucida Console, Courier New" FontSize="11"
                       Foreground="{StaticResource YellowBrush}"
                       HorizontalAlignment="Center" Margin="0,-12,0,12"/>
            <TextBlock x:Name="TxtStatus"
                       FontFamily="Lucida Console, Courier New" FontSize="13" FontWeight="Bold"
                       Foreground="{StaticResource CyanBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <Border BorderBrush="{StaticResource GreenBrush}" BorderThickness="2"
                    HorizontalAlignment="Center" Margin="0,0,0,20">
                <Grid x:Name="GameGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="100"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Row="0" Grid.Column="0" Tag="0,0" Click="Cell_Click" Style="{StaticResource CellBtn}"/>
                    <Button Grid.Row="0" Grid.Column="1" Tag="0,1" Click="Cell_Click" Style="{StaticResource CellBtn}"/>
                    <Button Grid.Row="0" Grid.Column="2" Tag="0,2" Click="Cell_Click" Style="{StaticResource CellBtn}"/>
                    <Button Grid.Row="1" Grid.Column="0" Tag="1,0" Click="Cell_Click" Style="{StaticResource CellBtn}"/>
                    <Button Grid.Row="1" Grid.Column="1" Tag="1,1" Click="Cell_Click" Style="{StaticResource CellBtn}"/>
                    <Button Grid.Row="1" Grid.Column="2" Tag="1,2" Click="Cell_Click" Style="{StaticResource CellBtn}"/>
                    <Button Grid.Row="2" Grid.Column="0" Tag="2,0" Click="Cell_Click" Style="{StaticResource CellBtn}"/>
                    <Button Grid.Row="2" Grid.Column="1" Tag="2,1" Click="Cell_Click" Style="{StaticResource CellBtn}"/>
                    <Button Grid.Row="2" Grid.Column="2" Tag="2,2" Click="Cell_Click" Style="{StaticResource CellBtn}"/>
                </Grid>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="[RESTART]" Style="{StaticResource SmallButton}" Click="BtnRestart_Click"/>
                <Button Content="[BACK]"    Style="{StaticResource SmallButton}"
                        Foreground="{StaticResource RedBrush}"
                        BorderBrush="{StaticResource RedBrush}"
                        Click="BtnBack_Click"/>
            </StackPanel>
        </StackPanel>

        <local:PixelOverlay x:Name="Overlay"/>
    </Grid>
</Page>
