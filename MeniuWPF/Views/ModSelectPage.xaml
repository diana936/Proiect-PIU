<Page x:Class="MeniuWPF.Views.ModSelectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource PrimaryBrush}">
    <StackPanel VerticalAlignment="Center" Margin="80,0">

        <TextBlock Text="&gt;&gt; SELECTEAZA MOD &lt;&lt;" Style="{StaticResource TitleText}" FontSize="18"/>

        <TextBlock x:Name="TxtJoc" Text=""
                   FontFamily="Lucida Console, Courier New" FontSize="12"
                   Foreground="{StaticResource YellowBrush}"
                   HorizontalAlignment="Center" Margin="0,-14,0,20"/>

        <Button Content="[1]  2 JUCATORI"       Style="{StaticResource GameButton}" Click="BtnDoi_Click"/>
        <Button Content="[2]  VS CALCULATOR"    Style="{StaticResource GameButton}" Click="BtnCalculator_Click"/>

        <Rectangle Height="2" Fill="{StaticResource DarkGreenBrush}" Margin="0,8"/>

        <Button Content="[Q]  INAPOI"
                Style="{StaticResource GameButton}"
                Foreground="{StaticResource RedBrush}"
                BorderBrush="{StaticResource RedBrush}"
                Click="BtnBack_Click"/>
    </StackPanel>
</Page>
